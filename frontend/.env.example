# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_GRAPHQL_URL=http://localhost:3000/graphql

# Geospatial Service
NEXT_PUBLIC_GEO_SERVICE_URL=http://localhost:8001

# Map Services
NEXT_PUBLIC_MAPBOX_TOKEN=pk_test_your_token_here
NEXT_PUBLIC_OPENROUTE_KEY=your_openroute_key

# Application Settings
NEXT_PUBLIC_APP_NAME=Real Estate Platform
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
NEXT_PUBLIC_FEATURE_3D_TOURS=true
NEXT_PUBLIC_FEATURE_AI_RECOMMENDATIONS=true
NEXT_PUBLIC_FEATURE_VIRTUAL_STAGING=false

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=
