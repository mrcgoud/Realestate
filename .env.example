# ============================================
# ENVIRONMENT CONFIGURATION FOR PRODUCTION
# ============================================

# Copy this file to .env and fill in production values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here_min_16_chars
DB_NAME=realestate_prod

# ============================================
# BACKEND CONFIGURATION
# ============================================
NODE_ENV=production
API_PORT=3000
API_URL=https://api.yourdomain.com
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
JWT_EXPIRATION=7d

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_GEO_SERVICE_URL=https://geo-service.yourdomain.com
NEXT_PUBLIC_APP_NAME=HireBuyer
FRONTEND_URL=https://app.yourdomain.com

# ============================================
# CACHE & REDIS
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# ELASTICSEARCH
# ============================================
ELASTICSEARCH_HOST=elasticsearch:9200
ELASTICSEARCH_NODE=http://elasticsearch:9200

# ============================================
# GEOSPATIAL SERVICES
# ============================================
GEO_SERVICE_URL=http://geo-service:8001
MAPLIBRE_API_KEY=your_maplibre_key_here
OPENROUTE_API_KEY=your_openroute_key_here

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# AWS/S3 CONFIGURATION (For file uploads)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=realestate-bucket
AWS_S3_REGION=us-east-1
AWS_S3_URL=https://your-bucket.s3.amazonaws.com

# ============================================
# PAYMENT GATEWAY (If applicable)
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project-id

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN=https://app.yourdomain.com
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ============================================
# FEATURES
# ============================================
ENABLE_3D_TOURS=true
ENABLE_AI_PREDICTIONS=true
ENABLE_GEOSPATIAL_ANALYSIS=true
ENABLE_BROKER_MODE=false

# ============================================
# COOLIFY SPECIFIC (Optional)
# ============================================
COOLIFY_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
COOLIFY_REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}
